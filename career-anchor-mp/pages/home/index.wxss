.greeting { color: #9B9189; font-size: 26rpx; }
.title { margin-top: 14rpx; line-height: 1.35; }
.start-card { position: relative; margin-top: 56rpx; padding: 52rpx 44rpx; border-radius: 28rpx; color: #fff; background: linear-gradient(135deg, #A88066, #DFC9B6); box-shadow: 0 18rpx 44rpx rgba(168,128,102,.22); }
.card-title { font-size: 40rpx; font-weight: 700; }
.card-desc { margin-top: 14rpx; opacity: .9; }
.arrow { position: absolute; right: 40rpx; top: 64rpx; font-size: 50rpx; }
.history-card { display: flex; align-items: center; justify-content: space-between; margin-top: 28rpx; }
.history-title { margin-bottom: 10rpx; color: #8A6A4F; font-size: 34rpx; font-weight: 650; }
.count { display: flex; align-items: center; justify-content: center; min-width: 64rpx; height: 64rpx; padding: 0 10rpx; border-radius: 32rpx; color: #8A6A4F; background: #EDE7DE; font-weight: 650; }
.disclaimer { margin-top: 72rpx; color: #9B9189; font-size: 23rpx; line-height: 1.6; text-align: center; }
