<view class="history-page">
  <view class="history-head">
    <view class="title">历史报告</view>
    <view class="subtitle">每一次选择，都记录着当时真正看重的职业价值。</view>
    <view wx:if="{{total > 0}}" class="total-pill">累计 {{total}} 次</view>
  </view>

  <view wx:if="{{loading && records.length == 0}}" class="state-card">
    <view class="state-mark">◌</view>
    <view>正在整理历史报告…</view>
  </view>

  <view wx:elif="{{error && records.length == 0}}" class="state-card">
    <view class="state-mark">!</view>
    <view class="state-title">暂时无法加载</view>
    <view class="state-desc">{{error}}</view>
    <button class="secondary-button" bindtap="retry">重新加载</button>
  </view>

  <view wx:elif="{{records.length == 0}}" class="state-card empty-card">
    <view class="empty-orbit"><view class="empty-core">锚</view></view>
    <view class="state-title">还没有测评记录</view>
    <view class="state-desc">完成第一次测评，从八种职业价值中找到最稳定的那一个。</view>
    <button class="primary-button" bindtap="start">去测一次</button>
  </view>

  <view wx:else class="history-list">
    <view class="history-card tone-{{item.tone}}" wx:for="{{records}}" wx:key="id" data-id="{{item.id}}" bindtap="open">
      <view class="card-top">
        <view class="date-block"><view class="date">{{item.date}}</view><view class="time">{{item.time}}</view></view>
        <view class="anchor-badge">{{item.top1Name}}</view>
      </view>
      <view class="card-label">TOP 3 职业锚</view>
      <view class="top3">{{item.top3Text}}</view>
      <view class="card-bottom"><text>报告编号 {{item.resultNo}}</text><text class="open-report">查看报告 →</text></view>
    </view>
    <view wx:if="{{loadingMore}}" class="load-more">正在加载更多…</view>
    <view wx:elif="{{!hasMore}}" class="load-more">已展示全部报告</view>
  </view>
</view>
