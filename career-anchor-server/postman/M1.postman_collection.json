{
  "info": {
    "name": "Career Anchor M1",
    "description": "M1 local flow: development WeChat login -> JWT -> questions. Start the app with the dev profile first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Development WeChat login",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('login succeeds', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.expect(body.code).to.eql(0);",
            "pm.collectionVariables.set('token', body.data.token);"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"code\": \"postman-local-user\"\n}" },
        "url": "{{baseUrl}}/auth/wx-login"
      }
    },
    {
      "name": "2. Get protected questions",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('questions succeed', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.expect(body.code).to.eql(0);",
            "pm.expect(body.data.questions).to.have.length(40);",
            "pm.expect(body.data.questions[0]).not.to.have.property('anchorCode');",
            "pm.expect(body.data.config.scaleMax).to.eql(6);",
            "pm.expect(body.data.config.boostCount).to.eql(3);",
            "pm.expect(body.data.config.boostValue).to.eql(4);"
          ]
        }
      }],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/questions"
      }
    }
  ]
}
