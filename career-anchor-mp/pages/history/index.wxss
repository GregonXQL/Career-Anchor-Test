.history-page { min-height: 100vh; padding: 40rpx 28rpx 72rpx; box-sizing: border-box; background: #f5f2ed; }
.history-head { position: relative; padding: 0 8rpx 24rpx; }
.total-pill { display: inline-block; margin-top: 20rpx; padding: 9rpx 18rpx; border-radius: 999rpx; color: var(--brand-deep); background: #e8dfd5; font-size: 22rpx; }
.state-card { margin-top: 80rpx; padding: 70rpx 38rpx; border-radius: 28rpx; background: #fff; color: var(--muted); text-align: center; box-shadow: 0 12rpx 36rpx rgba(71,66,62,.07); }
.state-mark { width: 84rpx; height: 84rpx; margin: 0 auto 28rpx; border-radius: 50%; background: #ede7de; color: var(--brand-deep); font-size: 52rpx; line-height: 84rpx; }
.state-title { color: var(--brand-deep); font-size: 34rpx; font-weight: 700; }
.state-desc { margin-top: 14rpx; font-size: 25rpx; line-height: 1.65; }
.empty-card { margin-top: 44rpx; }
.empty-orbit { position: relative; width: 150rpx; height: 150rpx; margin: 0 auto 34rpx; border: 2rpx solid #d8c8b9; border-radius: 50%; }
.empty-orbit::after { content: ''; position: absolute; top: 68rpx; left: -18rpx; width: 184rpx; height: 18rpx; border-top: 2rpx solid #c0a385; border-radius: 50%; transform: rotate(-24deg); }
.empty-core { position: absolute; top: 39rpx; left: 39rpx; z-index: 1; width: 72rpx; height: 72rpx; border-radius: 50%; color: #fff; background: linear-gradient(135deg,#a88066,#dfc9b6); font-size: 30rpx; line-height: 72rpx; }
.history-list { margin-top: 12rpx; }
.history-skeleton { margin-top: 12rpx; }
.skeleton-card { border-left-color: #D8CEC4; }
.skeleton-card .skeleton-line { margin-top: 28rpx; }
.skeleton-card .skeleton-line:first-child { height: 32rpx; margin-top: 0; }
.history-card { position: relative; margin-top: 22rpx; padding: 30rpx; overflow: hidden; border-radius: 24rpx; border-left: 8rpx solid #a88066; background: #fff; box-shadow: 0 10rpx 32rpx rgba(71,66,62,.07); }
.tone-deep { border-left-color: #765844; } .tone-copper { border-left-color: #a4755f; } .tone-champagne { border-left-color: #c0a385; } .tone-clay { border-left-color: #b08d7a; } .tone-taupe { border-left-color: #9b9189; } .tone-sand { border-left-color: #c7b39e; } .tone-oat { border-left-color: #d3c8bb; }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.date-block { display: flex; align-items: baseline; }
.date { color: #6b6059; font-size: 27rpx; font-weight: 600; }
.time { margin-left: 14rpx; color: var(--muted); font-size: 21rpx; }
.anchor-badge { padding: 9rpx 18rpx; border-radius: 999rpx; color: #fff; background: linear-gradient(135deg,#a88066,#c0a385); font-size: 23rpx; font-weight: 600; }
.card-label { margin-top: 30rpx; color: #b1a59c; font-size: 19rpx; letter-spacing: 3rpx; }
.top3 { margin-top: 10rpx; color: var(--brand-deep); font-size: 29rpx; font-weight: 600; }
.card-bottom { display: flex; justify-content: space-between; margin-top: 26rpx; padding-top: 20rpx; border-top: 1rpx solid #eee8e2; color: var(--muted); font-size: 21rpx; }
.open-report { color: var(--brand); font-weight: 600; }
.load-more { padding: 36rpx 0 12rpx; color: var(--muted); font-size: 22rpx; text-align: center; }
