.report-page { min-height: 100vh; padding: 24rpx 24rpx 72rpx; box-sizing: border-box; background: #f5f2ed; }
.state-card { margin-top: 180rpx; padding: 80rpx 36rpx; text-align: center; color: var(--muted); }
.state-mark { width: 88rpx; height: 88rpx; margin: 0 auto 28rpx; border-radius: 50%; background: var(--bg-oat); color: var(--brand-deep); font-size: 54rpx; line-height: 88rpx; }
.state-title { color: var(--brand-deep); font-size: 36rpx; font-weight: 700; }
.state-desc { margin-top: 12rpx; font-size: 26rpx; }
.report-skeleton { padding-top: 8rpx; }
.skeleton-hero { height: 300rpx; border-radius: 28rpx; background: #CFC0B2; }
.skeleton-score { height: 70rpx; margin-top: 28rpx; border-radius: 14rpx; }
.skeleton-radar { height: 430rpx; margin-top: 28rpx; border-radius: 50%; }
.loading-caption { padding: 30rpx 0; color: var(--muted); font-size: 23rpx; text-align: center; }
.hero { padding: 38rpx 36rpx 44rpx; border-radius: 28rpx; color: #fff; background: linear-gradient(135deg, #8a6a4f, #a88066 55%, #c0a385); box-shadow: 0 18rpx 44rpx rgba(104, 76, 55, .22); }
.hero-top { display: flex; justify-content: space-between; align-items: center; }
.eyebrow { font-size: 24rpx; letter-spacing: 3rpx; opacity: .78; }
.save-entry { padding: 10rpx 18rpx; border: 1rpx solid rgba(255,255,255,.48); border-radius: 999rpx; font-size: 22rpx; }
.save-entry.disabled { opacity: .55; }
.hero-title { margin-top: 34rpx; font-size: 54rpx; font-weight: 700; }
.hero-en { margin-top: 6rpx; font-size: 22rpx; opacity: .72; }
.hero-tagline { margin-top: 28rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,.24); font-size: 28rpx; line-height: 1.65; }
.section-card { margin-top: 24rpx; padding: 34rpx 30rpx; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 34rpx rgba(71,66,62,.07); }
.section-title { color: var(--brand-deep); font-size: 34rpx; font-weight: 700; }
.section-subtitle { margin-top: 8rpx; color: var(--muted); font-size: 22rpx; }
.score-list { margin-top: 30rpx; }
.score-row { margin-top: 26rpx; }
.score-meta { display: flex; justify-content: space-between; align-items: center; }
.score-name { display: flex; align-items: center; color: #5c534d; font-size: 27rpx; font-weight: 600; }
.rank { display: inline-flex; width: 36rpx; height: 36rpx; margin-right: 14rpx; align-items: center; justify-content: center; border-radius: 50%; background: #ede7de; color: #9b9189; font-size: 20rpx; }
.rank-top { color: #fff; background: linear-gradient(135deg, #a88066, #dfc9b6); }
.score-number { color: var(--brand-deep); font-size: 30rpx; font-weight: 700; }
.score-number text { margin-left: 3rpx; color: var(--muted); font-size: 19rpx; font-weight: 400; }
.bar-track { height: 16rpx; margin-top: 13rpx; overflow: hidden; border-radius: 999rpx; background: #eee9e3; }
.bar-fill { height: 100%; border-radius: 999rpx; animation: grow .7s ease-out; transform-origin: left; }
.bar-first { background: #8a6a4f; }
.bar-top { background: linear-gradient(90deg, #a88066, #c0a385); }
.bar-normal { background: #cfc4bb; }
.score-caption { margin: 8rpx 0 0 50rpx; color: var(--muted); font-size: 20rpx; }
@keyframes grow { from { transform: scaleX(0); } to { transform: scaleX(1); } }
.radar-card { overflow: hidden; }
.radar-canvas { width: 100%; height: 620rpx; margin-top: 12rpx; }
.details-title { margin: 42rpx 8rpx 20rpx; color: var(--brand-deep); font-size: 38rpx; font-weight: 700; }
.profile-card { margin-top: 20rpx; overflow: hidden; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 32rpx rgba(71,66,62,.07); border-left: 8rpx solid #a88066; }
.tone-deep { border-left-color: #765844; } .tone-copper { border-left-color: #a4755f; } .tone-champagne { border-left-color: #c0a385; } .tone-clay { border-left-color: #b08d7a; } .tone-taupe { border-left-color: #9b9189; } .tone-sand { border-left-color: #c7b39e; } .tone-oat { border-left-color: #d3c8bb; }
.profile-head { display: flex; align-items: center; padding: 30rpx 26rpx; }
.profile-rank { color: #d5c8bc; font-size: 48rpx; font-weight: 700; }
.profile-identity { flex: 1; margin-left: 24rpx; }
.profile-name { color: var(--brand-deep); font-size: 32rpx; font-weight: 700; }
.profile-tagline { margin-top: 8rpx; color: #776e68; font-size: 23rpx; line-height: 1.5; }
.chevron { margin-left: 16rpx; color: var(--brand); font-size: 38rpx; transition: transform .2s; }
.chevron.open { transform: rotate(180deg); }
.profile-body { padding: 0 28rpx 30rpx; border-top: 1rpx solid #eee8e2; }
.detail-section { margin-top: 32rpx; }
.detail-title { display: inline-block; padding: 7rpx 16rpx; border-radius: 999rpx; color: var(--brand-deep); background: #ede7de; font-size: 24rpx; font-weight: 700; }
.detail-item { margin-top: 22rpx; padding-left: 18rpx; border-left: 4rpx solid #dfc9b6; }
.detail-item-title { color: #5f554f; font-size: 27rpx; font-weight: 600; }
.detail-item-desc { margin-top: 7rpx; color: #776e68; font-size: 25rpx; line-height: 1.7; }
.report-footer { margin-top: 32rpx; padding: 30rpx; border-radius: 20rpx; background: #ede7de; }
.footer-line { display: flex; justify-content: space-between; margin-top: 12rpx; color: #81756d; font-size: 23rpx; }
.footer-disclaimer { margin-top: 26rpx; padding-top: 24rpx; border-top: 1rpx solid #d8cec4; color: #9b9189; font-size: 22rpx; line-height: 1.6; text-align: center; }
.home-button { margin-top: 30rpx; }
.poster-canvas { position: fixed; left: -200vw; top: 0; opacity: 0; pointer-events: none; }
