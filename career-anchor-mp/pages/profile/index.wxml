<view class="page profile-page">
  <view class="eyebrow">PERSONAL PROFILE</view>
  <view class="title">先让报告认识你</view>
  <view class="subtitle">昵称和头像仅用于区分、展示你的测评报告，你可以随时回来修改。</view>

  <view wx:if="{{loading}}" class="profile-card">
    <view class="avatar-skeleton skeleton"></view>
    <view class="skeleton skeleton-line medium"></view>
    <view class="skeleton skeleton-line"></view>
  </view>

  <view wx:else class="profile-card">
    <view class="avatar-wrap">
      <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">头像</view>
    </view>
    <view class="avatar-actions">
      <button class="avatar-button primary-avatar" open-type="chooseAvatar" bindchooseavatar="chooseWechatAvatar">使用微信头像</button>
      <button class="avatar-button" bindtap="chooseLocalAvatar">自己上传头像</button>
    </view>

    <view class="field-label">昵称</view>
    <input class="nickname-input" type="nickname" maxlength="64" value="{{nickname}}" placeholder="点击可选择微信昵称，也可自行输入" bindinput="nicknameInput" />
    <view class="field-tip">点击输入框后，可使用微信提供的昵称建议。</view>

    <button class="primary-button save-button" loading="{{saving}}" bindtap="save">保存并继续</button>
  </view>

  <view class="privacy-note">头像与昵称由你主动选择或填写，不会自动读取。</view>
</view>
